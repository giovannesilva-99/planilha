<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Plano de Corrida | Grupo BASE</title>
<style>
  :root{
    --navy:#23345B;
    --blue:#1C75BC;
    --gray:#6D6E71;
    --light:#F3F4F5;
    --white:#FFFFFF;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family:Arial, Helvetica, sans-serif;
    background:var(--light);
    color:#333;
    padding:30px 16px;
  }
  .card{
    max-width:900px;
    margin:0 auto;
    background:var(--white);
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 6px 24px rgba(0,0,0,.10);
  }
  header{
    background:var(--navy);
    padding:26px 32px;
    display:flex;
    align-items:center;
    justify-content:space-between;
  }
  header img{ height:40px; }
  header .titulo{
    text-align:right;
    color:var(--white);
  }
  header .titulo h1{
    margin:0;
    font-size:18px;
    font-weight:700;
    letter-spacing:.3px;
  }
  header .titulo p{
    margin:2px 0 0;
    font-size:12px;
    color:#B9C3D6;
  }

  table{
    width:100%;
    border-collapse:collapse;
  }
  thead th{
    background:var(--blue);
    color:var(--white);
    font-size:11.5px;
    text-transform:uppercase;
    letter-spacing:.4px;
    padding:12px 10px;
    text-align:left;
  }
  thead th:first-child{width:90px; text-align:center;}
  tbody td{
    padding:14px 12px;
    font-size:13px;
    vertical-align:top;
    border-bottom:1px solid #EAEAEA;
    white-space:pre-line;
    line-height:1.5;
  }
  tbody tr:nth-child(even) td{background:var(--light);}
  .semana{
    text-align:center;
    font-weight:800;
    color:var(--navy);
    font-size:14px;
  }
  .semana small{
    display:block;
    font-weight:600;
    font-size:9.5px;
    color:var(--gray);
    margin-top:2px;
  }

  footer{
    text-align:center;
    padding:14px;
    font-size:10.5px;
    font-style:italic;
    color:var(--gray);
    border-top:1px solid #EAEAEA;
  }
</style>
</head>
<body>

<div class="card">
  <header>
    <img src="data:image/png;base64," alt="Grupo BASE">
    <div class="titulo">
      <h1>PLANO DE TREINO DE CORRIDA</h1>
      <p>8 semanas · Objetivo: prova de 5km</p>
    </div>
  </header>

  <table>
    <thead>
      <tr>
        <th>Semana</th>
        <th>Terça</th>
        <th>Quinta</th>
        <th>Sábado</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="semana">1<small>Adaptação</small></td>
        <td>- Caminhada: 10 min
- Caminhada acelerada: 20 min</td>
        <td>- Caminhada: 10 min
- Alternar: 6x (3 min caminhada / 1 min trote)</td>
        <td>- Caminhada: 10 min
- Alternar: 5x (3 min caminhada / 2 min trote)
- Caminhada: 5 min</td>
      </tr>
      <tr>
        <td class="semana">2<small>Adaptação</small></td>
        <td>- Caminhada: 15 min
- Trote: 10 min
- Caminhada: 5 min</td>
        <td>- Caminhada: 5 min
- Alternar: 8x (2 min corrida leve / 2 min caminhada)</td>
        <td>- Caminhada: 10 min
- Alternar: 5x (5 min trote / 2 min caminhada)</td>
      </tr>
      <tr>
        <td class="semana">3<small>Condicionante</small></td>
        <td>- Corrida leve: 5 min
- Alternar: 5x (5 min corrida leve / 1 min caminhada)</td>
        <td>- Corrida leve: 10 min
- Alternar: 5x (3 min corrida moderada / 1 min caminhada)</td>
        <td>- Caminhada: 5 min
- Corrida leve: 20 min</td>
      </tr>
      <tr>
        <td class="semana">4<small>Condicionante</small></td>
        <td>- Caminhada: 5 min
- Corrida leve: 25 min</td>
        <td>- Corrida leve: 5 min
- Alternar: 5x (1 min corrida forte / 2 min corrida leve)
- Trote: 15 min</td>
        <td>- Caminhada: 5 min
- Corrida moderada: 30 min</td>
      </tr>
      <tr>
        <td class="semana">5<small>Condicionante</small></td>
        <td>- Caminhada: 10 min
- Corrida leve: 20 min
- Trote: 15 min</td>
        <td>- Trote: 10 min
- Alternar: 5x (2 min corrida forte / 2 min corrida leve)
- Caminhada: 5 min</td>
        <td>- Corrida leve: 30 min</td>
      </tr>
      <tr>
        <td class="semana">6<small>Aperfeiçoamento</small></td>
        <td>- Corrida leve: 5 min
- Corrida moderada: 30 min</td>
        <td>- Corrida leve: 10 min
- Alternar: 4x (2 min corrida forte / 3 min corrida leve)
- Trote: 15 min</td>
        <td>- Caminhada: 5 min
- Corrida moderada: 30 min</td>
      </tr>
      <tr>
        <td class="semana">7<small>Aperfeiçoamento</small></td>
        <td>- Trote: 5 min
- Corrida moderada: 30 min</td>
        <td>- Trote: 10 min
- Alternar: 6x (3 min corrida forte / 2 min corrida leve)
- Caminhada: 5 min</td>
        <td>- Corrida moderada: 30 min</td>
      </tr>
      <tr>
        <td class="semana">8<small>Objetivo</small></td>
        <td>- Caminhada: 5 min
- Corrida moderada: 35 min</td>
        <td>- Corrida leve: 30 min</td>
        <td><strong>PROVA DE 5KM</strong></td>
      </tr>
    </tbody>
  </table>

</div>

</body>
</html>
